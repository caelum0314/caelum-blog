---
import { UNCATEGORIZED } from '@constants/constants'
import I18nKey from '../i18n/i18nKey'
import { i18n } from '../i18n/translation'
import { getSortedPosts } from '../utils/content-utils'
import { getPostUrlBySlug } from '../utils/url-utils'
import Markdown from "@components/misc/Markdown.astro";

const { keyword, tags, categories } = Astro.props

let posts = await getSortedPosts()

// 筛选标签
if (Array.isArray(tags) && tags.length > 0) {
  posts = posts.filter(
    post =>
      Array.isArray(post.data.tags) &&
      post.data.tags.some(tag => tags.includes(tag)),
  )
}

// 筛选分类
if (Array.isArray(categories) && categories.length > 0) {
  posts = posts.filter(
    post =>
      (post.data.category && categories.includes(post.data.category)) ||
      (!post.data.category && categories.includes(UNCATEGORIZED)),
  )
}

// 按年和月分组
const yearGroups = {}

// 先按年分组
posts.forEach(post => {
  const year = post.data.published.getFullYear()
  if (!yearGroups[year]) {
    yearGroups[year] = []
  }
  yearGroups[year].push(post)
})

// 处理每年的文章，按月份分组
const groups = []
Object.keys(yearGroups).sort((a, b) => b - a).forEach(year => {
  const yearPosts = yearGroups[year]
  const monthGroups = {}
  
  // 按月份分组
  yearPosts.forEach(post => {
    const month = post.data.published.getMonth() + 1 // 1-12月
    if (!monthGroups[month]) {
      monthGroups[month] = []
    }
    monthGroups[month].push(post)
  })
  
  // 整理月份数据（按月份倒序）
  const months = []
  Object.keys(monthGroups).sort((a, b) => b - a).forEach(month => {
    months.push({
      month: parseInt(month),
      monthName: `${month}月`,
      posts: monthGroups[month],
      count: monthGroups[month].length
    })
  })
  
  groups.push({
    year: parseInt(year),
    months: months,
    totalCount: yearPosts.length
  })
})

// 格式化日期（月-日）
function formatDate(date) {
  const month = (date.getMonth() + 1).toString().padStart(2, '0')
  const day = date.getDate().toString().padStart(2, '0')
  return `${month}-${day}`
}

// 格式化标签
function formatTag(tag) {
  return tag.map(t => `#${t}`).join(' ')
}
---

<div class="card-base px-8 py-6">
  
  {groups.map(group => (
    <div>
      <!-- 年标题 -->
      <div class="flex flex-row w-full items-center h-[3.75rem]">
        <div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75">
          {group.year}
        </div>
        <div class="w-[15%] md:w-[10%]">
          <div class="h-3 w-3 bg-none rounded-full outline outline-[var(--primary)] mx-auto -outline-offset-[2px] z-50 outline-3"></div>
        </div>
        <div class="w-[70%] md:w-[80%] transition text-left text-50">
          {group.totalCount} {i18n(I18nKey.postsCount)}
        </div>
      </div>
      
      <!-- 月分组 -->
      {group.months.map(monthGroup => (
        <div>
          <!-- 月标题 -->
          <div class="flex flex-row w-full items-center h-[3rem]">
            <div class="w-[15%] md:w-[10%] transition text-xl font-bold text-right text-75">
              {monthGroup.monthName}
            </div>
            <div class="w-[15%] md:w-[10%]">
              <div class="h-2 w-2 bg-none rounded-full outline outline-[var(--primary)] mx-auto -outline-offset-[2px] z-50 outline-2"></div>
            </div>
            <div class="w-[70%] md:w-[80%] transition text-left text-50">
              {monthGroup.count} {i18n(I18nKey.postsCount)}
            </div>
          </div>
          
          <!-- 当月文章列表 -->
          {monthGroup.posts.map(post => (
            <a href={getPostUrlBySlug(post.slug)}
               aria-label={post.data.title}
               class="group btn-plain !block h-10 w-full rounded-lg hover:text-[initial]"
            >
              <div class="flex flex-row justify-start items-center h-full">
                <!-- 日期 -->
                <div class="w-[15%] md:w-[10%] transition text-sm text-right text-50">
                  {formatDate(post.data.published)}
                </div>
                <!-- 点和线 -->
                <div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
                  <div class="transition-all mx-auto w-1 h-1 rounded group-hover:h-5
                    bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-[var(--primary)]
                    outline outline-4 z-50
                    outline-[var(--card-bg)]
                    group-hover:outline-[var(--btn-plain-bg-hover)]
                    group-active:outline-[var(--btn-plain-bg-active)]
                  "></div>
                </div>
                <!-- 文章标题 -->
                <div class="w-[70%] md:max-w-[65%] md:w-[65%] text-left font-bold
                  group-hover:translate-x-1 transition-all group-hover:text-[var(--primary)]
                  text-75 pr-8 whitespace-nowrap overflow-ellipsis overflow-hidden"
                >
                  {post.data.title}
                </div>
                <!-- 标签列表 -->
                <div class="hidden md:block md:w-[15%] text-left text-sm transition
                  whitespace-nowrap overflow-ellipsis overflow-hidden
                  text-30"
                >{formatTag(post.data.tags)}</div>
              </div>
            </a>
          ))}
        </div>
      ))}
    </div>
  ))}
</div>
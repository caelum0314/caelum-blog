---

import { profileConfig } from '../config'
import { url } from '../utils/url-utils'
const currentYear = new Date().getFullYear()

const days = new Date().getTime() - new Date("2020/08/08").getTime()
const numberOfDays = (days / (1000 * 60 * 60 * 24)).toFixed()
---

<div class="card-base max-w-[var(--page-width)] min-h-[4.5rem] rounded-b-none mx-auto flex items-center px-6" 
     style="border-bottom-left-radius: 0 !important; border-bottom-right-radius: 0 !important;">
    <div class="transition text-50 text-sm">
        © 2023-{currentYear} {profileConfig.name} 版权所有
        <br>
        自豪地使用<a class="link text-[var(--primary)] font-medium" target="_blank" href="https://github.com/saicaca/fuwari"> Fuwari </a>主题
    </div>
</div>